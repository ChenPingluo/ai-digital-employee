# ==================== AI 数字员工系统环境变量配置模板 ====================
#
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际环境修改各项配置
# 3. 不要将 .env 文件提交到版本控制
#
# 注意：Docker Compose 会自动加载同目录下的 .env 文件
#

# ==================== 数据库配置 ====================
# PostgreSQL 用户名
POSTGRES_USER=postgres
# PostgreSQL 密码（生产环境请使用强密码）
POSTGRES_PASSWORD=your-secure-password-here
# 数据库名称
POSTGRES_DB=ai_employee

# 完整的数据库连接 URL（Docker 环境使用容器名作为主机名）
# 格式：postgresql+asyncpg://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql+asyncpg://postgres:your-secure-password-here@postgres:5432/ai_employee

# ==================== Redis 配置 ====================
# Redis 连接 URL（Docker 环境使用容器名作为主机名）
# 格式：redis://主机:端口/数据库编号
REDIS_URL=redis://redis:6379/0

# ==================== JWT 认证配置 ====================
# JWT 签名密钥（生产环境必须使用随机生成的强密钥）
# 可以使用以下命令生成：openssl rand -hex 32
SECRET_KEY=your-super-secret-jwt-key-please-change-in-production
# JWT 签名算法
ALGORITHM=HS256
# 访问令牌过期时间（分钟），默认24小时
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== 限流配置 ====================
# 单用户每秒请求限制
RATE_LIMIT_PER_USER=10
# 全局每秒请求限制
RATE_LIMIT_GLOBAL=500

# ==================== OpenAI / LLM 配置 ====================
# OpenAI API 密钥（或兼容 API 的密钥）
OPENAI_API_KEY=your-openai-api-key
# OpenAI API 基础 URL
# - 使用 OpenAI 官方：https://api.openai.com/v1
# - 使用本地 Ollama（Docker 中使用 host.docker.internal）：http://host.docker.internal:11434/v1
OPENAI_API_BASE=http://host.docker.internal:11434/v1
# 使用的 LLM 模型名称
LLM_MODEL_NAME=qwen2

# ==================== FastGPT 知识库配置 ====================
# FastGPT API URL（Docker 中使用 host.docker.internal 访问宿主机服务）
FASTGPT_API_URL=http://host.docker.internal:3000/api/v1/chat/completions
# FastGPT API 密钥
FASTGPT_API_KEY=your-fastgpt-api-key

# ==================== 天气 API 配置 ====================
# 心知天气 API 密钥（从 https://www.seniverse.com 获取）
WEATHER_API_KEY=your-weather-api-key
# 心知天气 API URL
WEATHER_API_URL=https://api.seniverse.com/v3/weather/now.json
# 是否启用天气与会议日程联动提醒
SCHEDULE_WEATHER_REMINDER_ENABLED=true
# 天气联动提醒查询的城市
WEATHER_REMINDER_CITY=扬州
