# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_employee
# Redis配置
REDIS_URL=redis://localhost:6379/0
# 限流配置
RATE_LIMIT_PER_USER=10
RATE_LIMIT_GLOBAL=500
# JWT配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# OpenAI / LLM 配置
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2
# FastGPT 配置
FASTGPT_API_URL=http://localhost:3000/api/v1/chat/completions
FASTGPT_API_KEY=your-fastgpt-api-key
# 天气API配置
WEATHER_API_KEY=your-weather-api-key
WEATHER_API_URL=https://api.seniverse.com/v3/weather/now.json
